# ─── Database (Neon PostgreSQL) ─────────────────────────────────────────────
# Pooled connection (for app queries via Prisma)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Direct connection (for Prisma migrations — remove -pooler from hostname)
DIRECT_URL="postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/neondb?sslmode=require"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Uploads ─────────────────────────────────────────────────────────────────
# Absolute path to uploads directory on the server
# Leave empty to use ./uploads relative to the process working directory
UPLOADS_DIR=/home/user/stocky/uploads

# ─── App URL ─────────────────────────────────────────────────────────────────
APP_URL=https://stocky.qodweb.com
