generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  barcode        String   @id
  name           String
  brand          String   @default("")
  techsheet      String   @default("")
  price          Decimal  @default(0) @db.Decimal(10, 2)
  buyprice       Decimal  @default(0) @db.Decimal(10, 2)
  reseller_price Decimal  @default(0) @db.Decimal(10, 2)
  provider       String   @default("")
  stock_levels   Json     @default("{}")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("products")
}

model AppUser {
  id                      String   @id @default(uuid())
  username                String   @unique
  pin                     String
  is_admin                Boolean  @default(false)
  can_create_quote        Boolean  @default(true)
  allowed_stock_locations String[] @default([])
  allowed_brands          String[] @default([])
  price_display_type      String   @default("normal")
  custom_seller_name      String?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  @@map("app_users")
}

model Quote {
  id             String   @id
  quote_number   String
  command_number String?
  status         String   @default("draft")
  customer_info  Json     @default("{}")
  items          Json     @default("[]")
  total_amount   Decimal  @default(0) @db.Decimal(10, 2)
  notes          String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("quotes")
}

model QuoteTemplate {
  id          String   @id
  name        String
  file_data   String   @db.Text
  file_type   String
  uploaded_at DateTime @default(now())
  is_active   Boolean  @default(false)

  @@map("quote_templates")
}

model Client {
  id           String   @id @default(uuid())
  full_name    String   @default("")
  phone_number String   @unique
  address      String   @default("")
  city         String   @default("")
  ice          String   @default("")
  email        String   @default("")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("clients")
}

model CompanySettings {
  id                   String   @id @default(uuid())
  company_name         String   @default("")
  address              String   @default("")
  phone                String   @default("")
  phone2               String   @default("")
  phone_dir            String   @default("")
  phone_gsm            String   @default("")
  email                String   @default("")
  website              String   @default("")
  ice                  String   @default("")
  rc                   String   @default("")
  if_number            String   @default("")
  cnss                 String   @default("")
  patente              String   @default("")
  logo_url             String?
  logo_size            String   @default("medium")
  quote_visible_fields Json     @default("{}")
  quote_style          Json     @default("{}")
  payment_terms        String   @default("30 jours")
  tva_rate             Decimal  @default(20) @db.Decimal(5, 2)
  quote_validity_days  Int      @default(30)
  updated_at           DateTime @updatedAt

  @@map("company_settings")
}

model ActivityLog {
  id          String   @id @default(uuid())
  user_id     String?
  username    String
  action      String
  details     String?
  entity_type String?
  entity_id   String?
  created_at  DateTime @default(now())

  @@map("activity_logs")
}

model ProductNameOverride {
  id            String   @id @default(uuid())
  type          String
  original_name String
  custom_name   String
  created_at    DateTime @default(now())

  @@unique([type, original_name])
  @@map("product_name_overrides")
}

model TechnicalSheet {
  id             String   @id @default(uuid())
  title          String   @default("")
  manufacturer   String   @default("")
  category       String   @default("")
  sector         String   @default("")
  file_url       String   @default("")
  file_size      BigInt   @default(0)
  file_type      String   @default("application/pdf")
  view_count     Int      @default(0)
  download_count Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  products TechnicalSheetProduct[]

  @@map("technical_sheets")
}

model TechnicalSheetProduct {
  id              String   @id @default(uuid())
  sheet_id        String
  product_barcode String
  created_at      DateTime @default(now())

  sheet TechnicalSheet @relation(fields: [sheet_id], references: [id], onDelete: Cascade)

  @@unique([sheet_id, product_barcode])
  @@map("technical_sheet_products")
}

model SheetShareLink {
  id         String    @id @default(uuid())
  token      String    @unique
  title      String?
  sheet_ids  String[]  @default([])
  expires_at DateTime?
  view_count Int       @default(0)
  created_at DateTime  @default(now())

  @@map("sheet_share_links")
}

model AiSettings {
  id         String   @id @default(uuid())
  provider   String?
  api_key    String?
  model      String?
  enabled    Boolean  @default(false)
  updated_at DateTime @updatedAt

  @@map("ai_settings")
}
